<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Password Game GOD MODE</title>
<style>
body { font-family: Arial; background:#050505; color:#eee; display:flex; flex-direction:column; align-items:center; padding:20px; }
input { padding:10px; width:360px; font-size:16px; border-radius:8px; border:none; }
.rules { margin-top:20px; width:380px; max-height:450px; overflow-y:auto; }
.rule { padding:6px; margin:4px 0; border-radius:6px; background:#222; font-size:12px; }
.valid { background:#1e7e34; }
#win { margin-top:20px; font-size:18px; color:#00ff88; display:none; }
footer { margin-top:40px; opacity:0.6; }
</style>
</head>
<body>
<h1>Password Game</h1>
<input id="password" placeholder="Enter password...">
<div class="rules" id="rules"></div>
<div id="win"></div>
<footer>© 2026 Sh4d0w</footer><script>
const rules = [
// BASIC → INSANE
{t:"Length ≥ 6",c:p=>p.length>=6},
{t:"Length ≥ 10",c:p=>p.length>=10},
{t:"Contains number",c:p=>/\d/.test(p)},
{t:"Contains uppercase",c:p=>/[A-Z]/.test(p)},
{t:"Contains lowercase",c:p=>/[a-z]/.test(p)},
{t:"Contains symbol",c:p=>/[^A-Za-z0-9]/.test(p)},
{t:"No spaces",c:p=>!/\s/.test(p)},
{t:"Starts with letter",c:p=>/^[A-Za-z]/.test(p)},
{t:"Ends with digit",c:p=>/\d$/.test(p)},
{t:"Contains 3 digits",c:p=>(p.match(/\d/g)||[]).length>=3},
{t:"Contains month",c:p=>/(january|february|march|april|may|june|july|august|september|october|november|december)/i.test(p)},
{t:"Contains weekday",c:p=>/(monday|tuesday|wednesday|thursday|friday|saturday|sunday)/i.test(p)},
{t:"Contains Roman numeral",c:p=>/(I|V|X|L|C|D|M)/.test(p)},
{t:"Digit sum = 18",c:p=>(p.match(/\d/g)||[]).reduce((a,b)=>a+ +b,0)===18},
{t:"Even length",c:p=>p.length%2===0},
{t:"3 vowels",c:p=>(p.match(/[aeiou]/gi)||[]).length>=3},
{t:"3 consonants",c:p=>(p.match(/[bcdfghjklmnpqrstvwxyz]/gi)||[]).length>=3},
{t:"Contains 42",c:p=>p.includes('42')},
{t:"No 123",c:p=>!p.includes('123')},
{t:"Contains palindrome",c:p=>/(.).\1/.test(p)},
{t:"Contains emoji",c:p=>/[\u{1F600}-\u{1F64F}]/u.test(p)},
{t:"Contains AI",c:p=>/AI/.test(p)},
{t:"Exactly 2 x",c:p=>(p.match(/x/g)||[]).length===2},
{t:"Contains color",c:p=>/(red|blue|green)/i.test(p)},
{t:"Contains country",c:p=>/(germany|france|japan)/i.test(p)},
{t:"Math symbol",c:p=>/[+\-*\/]/.test(p)},
{t:"Unique ≥ 8",c:p=>new Set(p).size>=8},
{t:"No triple repeat",c:p=>!/(.)\1\1/.test(p)},
{t:"Prime digit",c:p=>/[2357]/.test(p)},
{t:"Length > 15",c:p=>p.length>15},
{t:"Contains drowssap",c:p=>p.includes('drowssap')},
{t:"Digit sum = 22",c:p=>(p.match(/\d/g)||[]).reduce((a,b)=>a+ +b,0)===22},
{t:"Exactly 4 vowels",c:p=>(p.match(/[aeiou]/gi)||[]).length===4},
{t:"3 symbols",c:p=>(p.match(/[^A-Za-z0-9]/g)||[]).length>=3},
{t:"Contains 777",c:p=>p.includes('777')},
{t:"2 uppercase together",c:p=>/[A-Z]{2}/.test(p)},
{t:"3 digits in row",c:p=>/\d{3}/.test(p)},
{t:"Length %3 = 0",c:p=>p.length%3===0},
{t:"Contains zz",c:p=>p.includes('zz')},
{t:"No letter a",c:p=>!/a/i.test(p)},
{t:"Contains Hello in binary",c:p=>p.includes('0100100001100101011011000110110001101111')},
{t:"Contains 0xFF",c:p=>p.includes('0xFF')},
{t:"Contains base64 'test'",c:p=>p.includes('dGVzdA==')},
{t:"Contains '1337'",c:p=>p.includes('1337')},
{t:"Contains first two Digits after comma from π",c:p=>p.includes('3.14')},
{t:"Contains first 6 Digits of the Fibonacci Sequence",c:p=>p.includes('112358')},
{t:"Contains Morse SOS",c:p=>p.includes('...---...')},
{t:"Contains hex deadbeef",c:p=>p.toLowerCase().includes('deadbeef')},
{t:"Contains binary 101010",c:p=>p.includes('101010')},
{t:"Contains 'NaN'",c:p=>p.includes('NaN')},
{t:"Exactly 6 digits",c:p=>(p.match(/\d/g)||[]).length===6},
{t:"Length is prime",c:p=>{let l=p.length;if(l<2)return false;for(let i=2;i<l;i++)if(l%i===0)return false;return true;}},
{t:"Start = end char",c:p=>p[0]&&p[0]===p[p.length-1]},
{t:"Contains alternating case",c:p=>/[a-z][A-Z]|[A-Z][a-z]/.test(p)},
{t:"Unique ≥ 12",c:p=>new Set(p).size>=12},
{t:"Digit sum = 30",c:p=>(p.match(/\d/g)||[]).reduce((a,b)=>a+ +b,0)===30},
{t:"Contains '??'",c:p=>p.includes('??')},
{t:"Contains 'XY'",c:p=>p.includes('XY')},
{t:"Length > 25",c:p=>p.length>25},
{t:"Contains Unicode snowman",c:p=>p.includes('☃')}
];

const container=document.getElementById("rules");
rules.forEach((r,i)=>{
 const d=document.createElement("div");
 d.className="rule";
 d.id="rule-"+i;
 d.innerText="Rule " + (i+1);
 container.appendChild(d);
});

const input=document.getElementById("password");
const win=document.getElementById("win");

input.addEventListener("input",()=>{
 const val=input.value;
 let all=true;
 rules.forEach((r,i)=>{
  const ok=r.c(val);
  document.getElementById("rule-"+i).classList.toggle("valid",ok);
  if(!ok) all=false;
 });

 if(all){
  win.style.display="block";
  win.innerText="Congrats, Your Password is: "+val;
 } else {
  win.style.display="none";
 }
});
</script></body>
</html>
